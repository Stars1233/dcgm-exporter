# Single source of truth for pinned dependency versions.
#
# Bump a version here, then run `make sync-versions`.
# Use `make check-versions` to see which pins are outdated upstream.
# See CONTRIBUTING.md "Bumping a dependency" for the full flow.

# Go toolchain
GO_VERSION=1.26.4

# Python runner
UV_VERSION=0.11.27

